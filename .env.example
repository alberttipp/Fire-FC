# Supabase Configuration
# Get these from your Supabase project: Settings > API

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# NEVER commit the service role key to git!
# Only use this locally for admin scripts
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI feature flags — kept off by default. The browser-side Gemini calls
# were retired (would expose the API key in the public bundle). Re-enable
# only when these are routed through Supabase edge functions.
# VITE_AI_ASSISTANT_ENABLED=false
# VITE_AI_VOICE_ENABLED=false
# VITE_AI_SCOUTING_ENABLED=false

# Resend email delivery for coach feedback. Off until RESEND_API_KEY
# is set as a Supabase secret AND a sending domain is verified.
# VITE_RESEND_ENABLED=false

# Demo Mode Flag
# Set to 'true' to enable demo login buttons (for testing)
# Default: false (disabled in production)
VITE_USE_DEMO_DATA=false

# Sentry Error Monitoring (optional)
# Get from: https://sentry.io → Create Project → React
VITE_SENTRY_DSN=

# Staging Project Reference (for seed script safety)
# This should match your staging Supabase project ID
# VITE_STAGING_PROJECT_REF=nycprdmatvcprfujicoh
